# Copy to `.env` (git-ignored, never committed) and fill in.
# The orchestrator loads .env on startup and never prints these values.

# --- AWS credentials -----------------------------------------------------------
# boto3 resolves creds from its provider chain; the orchestrator never reads them.
# Pick ONE of:
#   (a) SSO / assumed role (recommended): set AWS_PROFILE and run `aws sso login`,
#       leave the key/secret blank.
#   (b) IAM user access keys: fill these in (throwaway test users only).
# On a cloud node LEAVE ALL OF THESE BLANK — the attached instance-profile role is
# discovered automatically. See docs/iam/ for the exact policies.
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- required: a globally-unique S3 bucket name for data/checkpoints/metrics ---
SPOT_TRAIN_BUCKET=your-unique-spot-train-bucket

# --- optional overrides (defaults shown) ---
# INSTANCE_TYPE=g4dn.xlarge
# AMI_ID=                       # pin an AMI id; otherwise auto-resolved via DescribeImages
# AMI_NAME_FILTER=Deep Learning OSS Nvidia Driver AMI GPU PyTorch*Ubuntu 22.04*
# REPO_URL=https://github.com/miguelaenlle/Spot-Distributed-LLM-Training.git
# REPO_BRANCH=main
# DATASET=shakespeare_char
# BASELINE_SECONDS=300
# SPOT_SEG1_SECONDS=120
# SPOT_SEG2_SECONDS=180
# CHECKPOINT_INTERVAL_SECONDS=30
# EVAL_ITERS=200
# BATCH_SIZE=12
