# Copy to `.env` (git-ignored, never committed) and fill in.
# The orchestrator loads .env on startup and never prints these values.

# --- AWS credentials -----------------------------------------------------------
# boto3 resolves creds from its provider chain; the orchestrator never reads them.
# Pick ONE of:
#   (a) SSO / assumed role (recommended): set AWS_PROFILE and run `aws sso login`,
#       leave the key/secret blank.
#   (b) IAM user access keys: fill these in (throwaway test users only).
# On a cloud node LEAVE ALL OF THESE BLANK — the attached instance-profile role is
# discovered automatically. See docs/iam/ for the exact policies.
# AWS_PROFILE=
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# --- required: a globally-unique S3 bucket name for data/checkpoints/metrics ---
SPOT_TRAIN_BUCKET=your-unique-spot-train-bucket

# --- optional overrides (defaults shown) ---
# INSTANCE_TYPE=g4dn.xlarge
# AMI_ID=                       # pin an AMI id; otherwise auto-resolved via DescribeImages
# AMI_NAME_FILTER=Deep Learning OSS Nvidia Driver AMI GPU PyTorch*Ubuntu*
# REPO_URL=https://github.com/miguelaenlle/Spot-Distributed-LLM-Training.git
# REPO_BRANCH=main
# DATASET=shakespeare_char
# BASELINE_SECONDS=300
# SPOT_SEG1_SECONDS=120
# SPOT_SEG2_SECONDS=180
# CHECKPOINT_INTERVAL_SECONDS=30
# EVAL_ITERS=200
# BATCH_SIZE=12

# --- preemption experiment (spot-orchestrate preempt) ---
# TRAIN_TOTAL_SECONDS=180        # total TRAINING seconds across all segments
# PREEMPT_COUNT=1                # number of kills; total is split across COUNT+1 segments
# PREEMPT_CHECKPOINT_SECONDS=5   # dense checkpoints so training-start is detected fast
# PREEMPT_GRACE=90               # wait for the SIGTERM checkpoint before terminating
# PREEMPT_AFTER=15               # train seconds before each kill (debug; 0 = even split)

# MARKET=on-demand               # run spot/preempt/ddp-preempt on on-demand capacity
#                                #   (same kill/resume mechanics; use when spot quota is 0)

# --- DDP experiment (spot-orchestrate ddp) ---
# DDP_NPROC_PER_NODE=            # blank/0 = one rank per GPU (auto). Set N to force N ranks (e.g. multi-rank DDP on a CPU box)
# DDP_DATA_MODE=shard            # shard (real data-parallel) | replicate (determinism check)

# --- optional: Weights & Biases visualization (install extra: pip install -e '.[viz]') ---
# Logging happens on the ORCHESTRATOR only; spot boxes never see this key. Unset
# WANDB_API_KEY => runs still write s3://<bucket>/runs/<id>/profile.json, just no W&B.
# WANDB_API_KEY=                # set to enable the W&B mirror
# WANDB_PROJECT=spot-train      # W&B project name (default: spot-train)
# WANDB_ENTITY=                 # your team/user; blank = your default entity
# WANDB_DISABLED=               # set to 1 to force-off even if a key is present
